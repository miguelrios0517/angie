---
import { Icon } from 'astro-icon/components';

export interface Props {
  icon?: string;
  title?: string;
  description?: string;
  backgroundColor?: string;
}

const {
  icon = 'tabler:info-square',
  title = await Astro.slots.render('title'),
  description = await Astro.slots.render('description'),
  backgroundColor = 'bg-blue-50',
} = Astro.props;
---

<section class=`${backgroundColor} dark:bg-slate-800 not-prose`>
  <div class="text-white max-w-6xl mx-auto px-4 sm:px-6 py-4 text-md text-center font-medium">
    <Icon name={icon} class="w-5 h-5 inline-block align-text-bottom font-bold" />
    <span class="font-bold" set:html={title} />
    <Fragment set:html={description} />
  </div>
</section>
