  <Hero2
    tagline="Coaching Personal Online"
    title="Consigue una Mente en Calma y la Confianza para Diseñar tu Futuro"
    subtitle="Transforma la saturacaión mental y la duda constante en una seguridad inquebrantable con herramientas prácticas que sí funcionan en el día a día."
    actions={[
      { variant: 'primary', text: 'Reservar Cita', href: '#', icon: 'tabler:square-rounded-arrow-right' },
      { text: 'Ver Programa', href: '#' },
    ]}
    image={{
      src: '~/assets/images/hero.jpg',
      alt: 'Click-through Landing Page Hero Image',
    }}
  />

  <!-- Note Widget ******************* -->

  <Note
    title="Angie Wong:"
    description="Coach & Experta en PNL con 18 años de trayectoria"
    backgroundColor="section-background-dark "
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Tu Laboratorio de Transformación"
    subtitle="Reprograma tu mente, libera el estrés y diseña una vida de auto-maestría."
    tagline="El Enfoque"
    items={[
      {
        title: 'Rompe el Autosabotaje Diario',
        description:
          'Desarmamos los bloqueos invisibles y las creencias limitantes con PNL, reconfigurando tu diálogo interno para que dejes de frenar tus proyectos y recuperes el control de tus decisiones.',
        icon: 'flat-color-icons:document',
      },
      {
        title: 'Libera Estrés desde el Cuerpo',
        description:
          'Desactivamos la alerta constante y la tensión acumulada en tu sistema nervioso con EFT Tapping e Hipnosis, transformando el desgaste diario en una calma interna e inquebrantable.',
        icon: 'flat-color-icons:template',
      },
      {
        title: 'Diseña una Mente Exitosa',
        description:
          'Pasa de sobrevivir a liderar tu vida con merecimiento real, alineando tu autoestima y tus hábitos diarios con tus metas más ambiciosas y un propósito de vida totalmente claro.',
        icon: 'flat-color-icons:voice-presentation',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-mist-grey dark:bg-transparent"></div>
    </Fragment>
  </Features2>

