    callToAction={{
      target: '_blank',
      text: 'Leer más testimonios',
      href: 'https://github.com/arthelokyo/astrowind',
      icon: 'tabler:chevron-right',
    }}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-canvas-white dark:bg-transparent"></div>
    </Fragment>
  </Testimonials>

