      Viaje estructurado de 12 semanas para reprogramar tu software mental, dominar tus emociones y consolidar tu auto-maestría.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-mist-grey dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    classes={{
      wrapper: 'section-background-gray',
    }}
    isAfterContent
    items={[
      {
        title: 'Laboratorios Temáticos',
        description:
          'Talleres prácticos enfocados en dominar el estrés, hackear el autosabotaje y desarrollar habilidades sociales de alto nivel.',
