  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="Coaching Personal Online"
    title="Elige tu Camino de Transformación (100% Virtual)"
    classes={{ container: 'services' }}
    items={[
      {
        title: 'Claridad en un Clic',
        description:
          'Identifica el origen exacto del estancamiento personal o relacional en sesiones uno a uno de alta eficiencia.',
      },
      {
        title: 'Herramientas de Rescate',
        description:
          'Llévate ejercicios prácticos de PNL y liberación somática para aplicar en tu día a día desde el primer encuentro.',
      },
      {
        title: 'Sintonía y Comunicación',
        description:
          'Espacio seguro para parejas que buscan desarmar dinámicas destructivas y construir metas en común con total coherencia.',
      },
    ]}
    image={{
      src: '~/assets/images/individual_cropped.jpg',
      alt: 'Colorful Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-primary-navy text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Sesión Individual/Pareja (50 minutos)
      </h3>
      Espacio dinámico para resolver bloqueos inmediatos, calibrar tus emociones o alinear metas en tu relación de forma online.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-mist-grey dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Arquitectura del Cambio',
        description: `12 encuentros semanales guiados paso a paso para auditar tu psique, limpiar el pasado y diseñar tu futuro.`,
      },
      {
        title: 'Enfoque Multi-Técnica',
        description:
          'Acceso completo a dinámicas de Hipnosis Ericksoniana, EFT Tapping avanzado y reestructuración de tu línea del tiempo.',
