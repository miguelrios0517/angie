---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Layout from '~/layouts/PageLayoutAngie.astro';
import FAQs from '~/components/widgets/FAQs.astro';

const metadata = {
  title: 'Services',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Servicios"
    title="Talleres y Sesiones Grupales"
    subtitle="Transformación colectiva: Talleres y clases en grupo que inspiran el cambio real."
    actions={[{ variant: 'primary', text: 'Explorar servicio', href: '/talleres-grupos#intro' }]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1740&q=80',
      alt: 'AstroWind Hero Image',
    }}
  />

  <!-- Content Widget **************** -->

  <Content
    id="intro"
    isReversed
    image={{
      src: 'https://images.unsplash.com/photo-1525909002-1b05e0c869d8?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=870&q=80',
      alt: 'Features Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Talleres y Sesiones Grupales<span class="font-normal"></span>
      </h3>
      <p>
        Espacios de crecimiento compartido, reflexión profunda y herramientas prácticas para transformar el bienestar
        emocional, personal y profesional en comunidad.<br /><br />El crecimiento personal no tiene por qué ser un
        camino solitario. Las sesiones grupales y los talleres ofrecen una dinámica única donde el aprendizaje se
        potencia a través de las experiencias compartidas, la resonancia con otros y el soporte de un entorno seguro y
        confidencial guiado por un profesional.
      </p>
    </Fragment>
  </Content>
  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Validación',
        description:
          'Descubrir que otros comparten inquietudes y desafíos similares alivia el aislamiento y fortalece la autocompasión',
        icon: 'tabler:clock',
      },
      {
        title: 'Perspectiva',
        description:
          'Escuchar diferentes puntos de vista y soluciones enriquece el propio repertorio de afrontamiento y resolución de problemas.',
        icon: 'tabler:school',
      },
      {
        title: 'Acción',
        description:
          'El compromiso con un grupo impulsa la responsabilidad personal y la aplicación real de las herramientas aprendidas.',
        icon: 'tabler:coin',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664688-cf412ec27db2?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
      alt: 'Benefits Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        ¿Por qué elegir el formato grupal?
      </h3>
      <p>
        A diferencia del proceso individual, el trabajo en grupo actúa como un espejo amplificado. Permite a los
        participantes identificar patrones comunes, normalizar sus procesos emocionales y adquirir herramientas
        prácticas mediante dinámicas interactivas y vivenciales. Es un entorno idóneo para consolidar habilidades de
        comunicación, resiliencia y autoconocimiento.
      </p>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    items={[
      {
        title: 'Regulación Emocional y Mindfulness',
        description:
          'Herramientas prácticas para identificar, comprender y canalizar el estrés y la ansiedad cotidiana desde la atención plena.',
        icon: 'tabler:wand',
      },
      {
        title: 'Crecimiento Personal y Transiciones',
        description:
          'Espacios de claridad enfocados en momentos de cambio, desmontaje de creencias limitantes y diseño de metas alineadas con tu propósito.',
        icon: 'tabler:settings',
      },
      {
        title: 'Vínculos, Asertividad y Límites',
        description:
          'Encuentros dedicados a mejorar la comunicación, construir relaciones más saludables y aprender a establecer límites firmes sin culpa.',
        icon: 'tabler:presentation',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1525909002-1b05e0c869d8?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=870&q=80',
      alt: 'Features Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Nuestras Líneas de Trabajo</h3>
      <p>Exploramos el crecimiento personal y el bienestar emocional a través de tres ejes temáticos esenciales:</p>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    items={[
      {
        title: 'Encuadre Conceptual',
        description:
          'Una breve introducción teórica, clara y sin tecnicismos, para entender el "por qué" de lo que trabajamos.',
        icon: 'tabler:wand',
      },
      {
        title: 'Dinámicas Experienciales',
        description: 'Ejercicios prácticos e interactivos para integrar el contenido de manera activa.',
        icon: 'tabler:settings',
      },
      {
        title: 'Espacio de Cocuración',
        description:
          'Puesta en común (siempre voluntaria) para resolver dudas, compartir hallazgos y procesar la experiencia bajo supervisión profesional.',
        icon: 'tabler:presentation',
      },
      {
        title: 'Herramientas de Integración',
        description:
          'Recursos complementarios o guías de trabajo para que puedas seguir practicando e interiorizando lo aprendido durante la semana.',
        icon: 'tabler:presentation',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1525909002-1b05e0c869d8?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=870&q=80',
      alt: 'Features Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Metodología de Trabajo</h3>
      <p>
        Cada taller o ciclo grupal se fundamenta en un marco teórico científico y riguroso (combinando la Psicología
        Cognitivo-Conductual, el enfoque Humanista y el Coaching), estructurado de forma digerible y vivencial. Nuestros
        encuentros suelen estructurarse en cuatro pilares:
      </p>
    </Fragment>
  </Content>

  <!-- Testimonials Widget *********** -->

  <Testimonials
    title="Lo que dicen quienes han participado"
    testimonials={[
      {
        testimonial: `The designs are not only visually appealing but also highly professional. The templates have saved me a significant amount of time while helping me make a lasting impression on my clients.`,
        name: 'Emily Kennedy',
        job: 'Front-end developer',
        image: {
          src: 'https://images.unsplash.com/photo-1618835962148-cf177563c6c0?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=930&q=80',
          alt: 'Emily Kennedy Image',
        },
      },
      {
        testimonial: `It beautifully showcases my work, with its clean and elegant design that lets my photographs shine. Customization was a breeze, even for a non-tech person like me. The result is a professional and immersive portfolio that's garnered numerous compliments.`,
        name: 'Sarah Hansen',
        job: 'Photographer',
        image: {
          src: 'https://images.unsplash.com/photo-1561406636-b80293969660?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
          alt: 'Sarah Hansen Image',
        },
      },
      {
        testimonial: `I discovered these templates and I'm impressed by their variety and quality. They've helped me establish a consistent brand image across my marketing and social platforms, elevating my business's overall appearance.`,
        name: 'Mark Wilkinson',
        job: 'Small business owner',
        image: {
          src: 'https://images.unsplash.com/photo-1545167622-3a6ac756afa4?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=824&q=80',
          alt: 'Mark Wilkinson Image',
        },
      },
    ]}
    callToAction={{
      target: '_blank',
      text: 'More testimonials...',
      href: 'https://github.com/arthelokyo/astrowind',
      icon: 'tabler:chevron-right',
    }}
  />

  <FAQs
    title="Preguntas Frecuentes"
    subtitle="Respuestas rápidas a las dudas más comunes sobre nuestros espacios grupales."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: '¿Cómo sé si es mejor para mí un proceso individual o uno grupal?',
        description:
          'El grupo es ideal para adquirir herramientas y compartir vivencias. Si buscas tratar un tema muy específico o de alta complejidad diagnóstica, la terapia individual es el espacio idóneo. Ambos formatos son complementarios.',
      },
      {
        title: 'Me da un poco de timidez hablar en público, ¿es obligatorio participar?',
        description:
          'No, el respeto a tu ritmo es fundamental. Compartir experiencias es siempre voluntario. Puedes beneficiarte de las dinámicas y escuchar a los demás sin necesidad de exponer detalles que prefieras reservar',
      },
      {
        title: '¿Cuál es el perfil de la persona que facilita estos espacios?',
        description:
          'Son guiados por Angie Wong, quien combina la rigurosidad y base científica de la psicología clínica con el dinamismo y la orientación a metas del coaching estratégico para ofrecer una experiencia práctica.',
      },
      {
        title: '¿Cuántas personas forman cada grupo?',
        description:
          'Para garantizar que el espacio sea seguro, confidencial y que todos reciban una atención de calidad, trabajamos con cupos limitados, manteniendo un máximo de 10 a 12 participantes por ciclo.',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-mist-grey dark:bg-transparent"></div>
    </Fragment>
  </FAQs>

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Consultar próximos talleres',
        href: '/',
      },
    ]}
    title="¿Te interesa participar en nuestro próximo espacio grupal?"
    subtitle="Si quieres conocer las temáticas activas, las próximas fechas confirmadas o te interesa llevar uno de estos talleres a tu organización, ponte en contacto para recibir la información actualizada."
  />
</Layout>
