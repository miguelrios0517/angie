import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText tagline="Contacto" title="Tu bienestar empieza aquí" />

  <!-- <ContactUs
    id="form"
    title="Da el primer paso"
    subtitle="Si buscas apoyo psicológico o quieres alcanzar una meta con sesiones de coaching, estás en el lugar correcto. Escríbeme con total confianza; este es un espacio seguro y confidencial. Te responderé en menos de 24 horas."
    button="Solicitar información"
    inputs={[
      {
        type: 'text',
        name: 'nombre',
        label: 'Nombre',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email',
      },
    ]}
    textarea={{
      label: 'Mensaje',
    }}
  /> -->

  <!-- Features2 Widget ************** -->

  <Features2
    title="¿Listo para avanzar?"
    subtitle="Si buscas apoyo psicológico o quieres alcanzar una meta con sesiones de coaching, estás en el lugar correcto. Contáctame directamente por WhatsApp en un espacio 100% seguro y confidencial. Te responderé en menos de 24 horas."
    id="contact-info"
    items={[
      {
        title: 'Espacio 100% confidencial',
        description: `Todo lo que compartas aquí se queda aquí. Un entorno seguro, privado y sin juicios.`,
      },
