---
import Layout from '~/layouts/PageLayoutAngie.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText tagline="Contacto" title="Tu bienestar empieza aquí" />

  <ContactUs
    id="form"
    title="Da el primer paso"
    subtitle="Si buscas apoyo psicológico o quieres alcanzar una meta con sesiones de coaching, estás en el lugar correcto. Escríbeme con total confianza; este es un espacio seguro y confidencial. Te responderé en menos de 24 horas."
    button="Solicitar información"
    inputs={[
      {
        type: 'text',
        name: 'nombre',
        label: 'Nombre',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email',
      },
    ]}
    textarea={{
      label: 'Mensaje',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Contacto"
    items={[
      {
        title: 'Espacio 100% confidencial',
        description: `Todo lo que compartas aquí se queda aquí. Un entorno seguro, privado y sin juicios.`,
      },
      {
        title: 'Sesiones a tu medida',
        description: 'Terapia y coaching adaptados a tu ritmo, tus necesidades y tus horarios.',
      },
      {
        title: 'Respuesta en menos de 24h',
        description: 'No te quedarás esperando. Recibirás una respuesta humana y cercana en un día hábil.',
      },
      {
        title: 'WhatsApp',
        description: '+51 987 717 886',
        icon: 'tabler:headset',
      },
      {
        title: 'Email',
        description: 'angiewong.psicologa@gmail.com',
        icon: 'tabler:mail',
      },
      {
        title: 'Locación',
        description: 'Lima, Peru',
        icon: 'tabler:map-pin',
      },
    ]}
  />
</Layout>
