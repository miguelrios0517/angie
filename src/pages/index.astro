    tagline="Cómo te puedo ayudar"
    id="servicios"
    title="Mis Servicios y Programas"
    classes={{ container: 'services' }}
    items={[
      {
        title: 'Claridad Emocional',
        description: 'Comprende tus pensamientos para reducir la ansiedad, el estrés y el sobrepensamiento.',
      },
      {
        title: 'Herramientas Prácticas',
        description: 'Aprende estrategias para manejar situaciones difíciles y decidir con seguridad.',
      },
      {
        title: 'Enfoque Personalizado',
        description: 'Recibe orientación adaptada a tus objetivos y ritmo personal.',
      },
    ]}
    image={{
      src: 'https://assets.angiewongpsi.com/individual_cropped.jpg',
      alt: 'Sesión individual con Angie Wong',
    }}
    callToAction={{
      text: 'Más información',
      icon: 'tabler:chevron-right',
      href: 'sesion-individual',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-primary-navy text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Sesión Individual/Pareja (50 min)
      </h3>
      Espacio privado para abordar tus desafíos actuales de forma inmediata y personalizada.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-mist-grey dark:bg-transparent"></div>
    </Fragment>
  </Content>
  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Apoyo Constante en Cada Paso',
        description:
          'Cuenta con acompañamiento continuo mientras trabajas en tus metas personales y desarrollas nuevas formas de afrontar los desafíos de la vida.',
      },
      {
        title: 'Un Camino Claro Hacia el Cambio',
        description:
          'Sigue un plan diseñado para ayudarte a ganar claridad, desarrollar hábitos más saludables y construir una vida más alineada con lo que realmente valoras.',
      },
      {
        title: 'Resultados que Perduran',
        description:
          'Desarrolla habilidades y herramientas que te permitirán mantener tu crecimiento personal y bienestar emocional a largo plazo.',
      },
    ]}
    image={{
      src: 'https://assets.angiewongpsi.com/hiking_cropped.jpg',
      alt: 'Blueprint Image',
    }}
    callToAction={{
      text: 'Más información',
      icon: 'tabler:chevron-right',
      href: 'programa-12-semanas',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-primary-navy text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Programa de Transformación (12 Semanas)
      </h3>
      Un proceso profundo y estructurado para superar bloqueos, desarrollar hábitos saludables y crear cambios positivos que
      perduren.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-mist-grey dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    classes={{
      wrapper: 'section-background-gray',
    }}
    isAfterContent
    items={[
      {
