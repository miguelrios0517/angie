---
import Layout from '~/layouts/PageLayoutAngie.astro';

import Header from '~/components/widgets/Header.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Steps from '~/components/widgets/Steps.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import { getPermalink } from '~/utils/permalinks';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Personal Homepage Demo',
};
---

<Layout metadata={metadata}>
  <Fragment slot="announcement"></Fragment>

  <!-- Hero2 Widget ******************* -->

  <Hero
    id="hero"
    title="Angie Wong"
    tagline="Sobre Angie"
    actions={[
      {
        variant: 'primary',
        text: 'Agendar Sesión Virtual',
        target: '_blank',
        href: 'https://wa.me/51987717886?text=Hola%20Psic.%20Angie%2C%20me%20gustar%C3%ADa%20solicitar%20la%20consulta%20gratuita%20de%2010%20minutos%20para%20conocer%20m%C3%A1s%20sobre%20las%20sesiones.',
      },
    ]}
  >
    <Fragment slot="subtitle">
      Psicóloga Clínica, Coach Mental & Master en PNL CPP. 14690. <br /><br /> Ofrezco un enfoque integral, compasivo e innovador
      en el cuidado de la salud mental. Adapto cada herramienta a la historia y necesidades únicas de mis pacientes para transformar
      el análisis del pasado en cambios medibles en su identidad, hábitos y bienestar.
    </Fragment>
  </Hero>

  <!-- Content Widget **************** -->

  <Content
    id="about"
    columns={3}
    items={[
      {
        icon: 'tabler:brand-whatsapp',
        callToAction: {
          target: '_blank',
          text: 'WhasApp',
          href: 'https://wa.me/51987717886?text=Hola%20Psic.%20Angie%2C%20me%20gustar%C3%ADa%20solicitar%20la%20consulta%20gratuita%20de%2010%20minutos%20para%20conocer%20m%C3%A1s%20sobre%20las%20sesiones.',
        },
      },
      {
        icon: 'tabler:brand-instagram',
        callToAction: {
          target: '_blank',
          text: 'Instagram',
          href: 'https://www.instagram.com/psic.angiewong?igsh=cmNtcDV4d3Buc3Fz',
        },
      },
      {
        icon: 'tabler:brand-tiktok',
        callToAction: {
          target: '_blank',
          text: 'TikTok',
          href: 'https://www.tiktok.com/@psico.angiewong?_r=1&_t=ZT-977uMlhAWhZ',
        },
      },
    ]}
    image={{
      src: '~/assets/images/angiewong.jpg',
      alt: 'Colorful Image',
      loading: 'eager',
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Perfil Profesional (Biografía Narrativa)
      </h2>
      <p>
        Soy Licenciada en Psicología y me especializo en guiar a las personas a superar desafíos emocionales y clínicos
        complejos, tales como la ansiedad, la depresión y los trastornos de personalidad
      </p>
      <br />
      <p>
        Mi práctica se distingue por fusionar la rigurosidad de la Psicología Clínica con el dinamismo estratégico de la
        Programación Neurolingüística (PNL) y el Coaching. Cuento con maestrías en Psicología Clínica y de la Salud y en
        Terapia del Bienestar Emocional (Madrid, España), lo que me permite abordar la salud mental desde una
        perspectiva integral: conectando mente, cuerpo y emociones.
      </p>
      <br />
      <p>
        Además de mi trayectoria en consulta particular, he sido docente universitaria durante más de una década, una
        experiencia clave que alimenta constantemente mi actualización profesional.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    id="resume"
    title="Trayectoria Académica"
    items={[
      {
        title: `Máster en Terapia del Bienestar Emocional<br /> <span class="font-normal">CEU Universidad San Pablo (Madrid, España)</span> <br /> <span class="text-sm font-normal">2020 - 2021</span>`,
        icon: 'tabler:school',
      },
      {
        title: `Maestría en Psicología Clínica y de la Salud<br /> <span class="font-normal">Universidad de San Martín de Porres</span> <br /> <span class="text-sm font-normal">2008 - 2010</span>`,
        icon: 'tabler:school',
      },
      {
        title: `Licenciatura en Psicología y Humanidade<br /> <span class="font-normal">Universidad Femenina del Sagrado Corazón (UNIFE)</span> <br /> <span class="text-sm font-normal">2000 - 2006</span>`,
        icon: 'tabler:school',
      },
      {
        title: `Certificación Internacional en Coaching Neurológico<br /> <span class="font-normal">Jamming Consultoría</span> <br /> <span class="text-sm font-normal">2017</span>`,
        icon: 'tabler:school',
      },
      {
        title: `Certificación Internacional en Gestión de la Innovación<br /> <span class="font-normal">Latam Coaching Network</span> <br /> <span class="text-sm font-normal">2018</span>`,
        icon: 'tabler:school',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    id="resume"
    title="Experiencia Clave"
    items={[
      {
        title:
          'Consultorio Particular <br /> <span class="font-normal">Consulto Personal, Lima</span> <br /> <span class="text-sm font-normal">2007 - Actualidad</span>',
        description: `Psicóloga Clínica y Coach orientada a adolescentes y adultos en manejo de estrés, crisis de pareja, ansiedad, depresión y trastornos de la conducta alimentaria (anorexia/bulimia).`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Docencia Universitaria <br /> <span class="font-normal">Universidad Continental y Alas Peruanas, Lima</span> <br /> <span class="text-sm font-normal">2008 - 2021</span>',
        description: `Profesora de pregrado y modalidades virtuales en la Universidad Continental y la Universidad Alas Peruanas, dictando asignaturas como Psicología Clínica, Técnicas Psicoterapéuticas y Psicología de la Motivación.`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Investigación y Desarrollo Social <br /> <span class="font-normal">Miniesterio de Educacion, Lima</span> <br /> <span class="text-sm font-normal">2008 - 2021</span>',
        description: `Evaluadora de proyectos educativos para el Ministerio de Educación y psicóloga de investigación de mercados en 360° Inteligencia de Mercados IBC.`,
        icon: 'tabler:briefcase',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="Certificaciones & Habilidades Clave"
    subtitle="Integración de herramientas clínicas y estratégicas para una transformación profunda."
    columns={3}
    defaultIcon="tabler:point-filled"
    items={[
      {
        title: 'EFT Tapping',
        description: 'Liberación emocional para procesar bloqueos internos y reducir el estrés físico.',
      },
      {
        title: 'Programación Neurolingüística (PNL)',
        description: 'Reestructuración de patrones de pensamiento y optimización de la comunicación interna.',
      },
      {
        title: 'Hipnosis Ericksoniana',
        description: 'Modificación de conductas arraigadas mediante el acceso guiado al inconsciente.',
      },
      {
        title: 'Gestión de la Innovación',
        description: 'Enfoque metodológico moderno y ágil para encontrar soluciones clínicas efectivas.',
      },
      {
        title: 'Coaching Neurológico',
        description: 'Potenciación de habilidades individuales para maximizar el rendimiento personal.',
      },
      {
        title: 'Consultoría en PNL',
        description: 'Diseño de estrategias personalizadas para superar creencias limitantes rápidamente.',
      },
      {
        title: 'Coaching Metódico',
        description: 'Acompañamiento enfocado en superar obstáculos y alcanzar metas individuales reales.',
      },
      {
        title: 'Enfoque Transpersonal',
        description: 'Integración de la sombra junguiana y arquetipos para sanar la identidad profunda.',
      },
      {
        title: 'Time Line Therapy®',
        description: 'Desensibilización de eventos del pasado para liberar cargas emocionales flotantes.',
      },
    ]}
  />

  <!-- PNL **************** -->

  <Content
    id="porfolio"
    title="Mi Metodología: ¿Cómo trabajo con la PNL?"
    subtitle="Un enfoque clínico y estratégico para transformar el análisis del pasado en cambios medibles en tu identidad, hábitos y bienestar."
    isReversed
    image={{
      src: 'https://images.unsplash.com/photo-1658248165252-71e116af1b34?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=928&q=80',
      alt: 'Tech Design Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        El Concepto:<br /><span class="text-2xl">¿Qué es la PNL?</span>
      </h3>
      <p>
        Imagina la PNL como el manual de usuario de tu propio cerebro. Tu mente funciona a través de un software que se
        ha ido programando desde la infancia con base en tus experiencias, miedos y entorno<br /><br />La PNL es un
        conjunto de herramientas prácticas que nos permite auditar ese sistema, identificar los pensamientos limitantes
        y reprogramar tu cerebro para que reaccione con calma, seguridad y claridad, en lugar de activar el estrés de
        manera automática.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Content
    isReversed
    isAfterContent={true}
    items={[
      {
        title: 'Programación',
        description: 'Sustitución de patrones de ansiedad y autosabotaje por automatismos enfocados en tu bienestar.',
      },
      {
        title: 'Neuro',
        description: `Optimización del sistema nervioso y de la forma en que tu cerebro procesa y almacena el estrés.`,
      },
      {
        title: 'Lingüística',
        description: `Reestructuración del lenguaje y del diálogo interno que programan directamente tus emociones.`,
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1619983081563-430f63602796?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
      alt: 'Art and Music Poster Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Los Componentes:<br /><span class="text-2xl">Los Pilares del Cambio</span>
      </h3>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Content
    isReversed
    isAfterContent={true}
    items={[
      {
        title: 'Descodificación de Creencias',
        description: `Uso de Hipnosis Ericksoniana Ligera (trance conversacional) para detectar y desactivar bloqueos inconscientes sin generar resistencias.`,
      },
      {
        title: 'Edición Mental y Alivio Somático',
        description: `Combinación de PNL y EFT Tapping Clínico para alterar la estructura de recuerdos dolorosos, reducir el cortisol y liberar el estrés del cuerpo.`,
      },
      {
        title: 'Anclajes de Alto Rendimiento',
        description: `Uso de Hipnosis Profunda para sembrar disparadores corporales en tu inconsciente, permitiéndote acceder a estados de calma y enfoque a voluntad.`,
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1664455340023-214c33a9d0bd?ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=870&q=80',
      alt: 'Fashion e-commerce Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        La Aplicación: <br /><span class="text-2xl">Tres Ejes de Acción en Sesión</span>
      </h3>
      <p>Procesos lógicos diseñados para transformar tu realidad interna:</p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Testimonials Widget *********** -->

  <Testimonials
    title="Lo Que Dicen Mis Clientes"
    subtitle="Testimonios e historias reales de superación, claridad y crecimiento personal."
    testimonials={[
      {
        testimonial: `Llegué al consultorio viviendo en piloto automático, con una ansiedad constante que no me dejaba tomar decisiones. El enfoque de Angie con PNL y Tapping me dio herramientas reales. Por fin siento que recuperé el control de mi mente y de mi día a día.`,
        name: 'Marcos Torres',
        job: 'Emprendedor Digital',
        image: {
          src: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
          alt: 'Marcos Torres Image',
        },
      },
      {
        testimonial: `Buscaba herramientas prácticas, no solo hablar de mis problemas. Las sesiones de Hipnosis Ericksoniana me ayudaron a desactivar bloqueos inconscientes que venía arrastrando desde hace años en mi carrera y relaciones. Totalmente medible.`,
        name: 'Emilia Martínez',
        job: 'Directora de Proyectos',
        image: {
          src: 'https://images.unsplash.com/photo-1554151228-14d9def656e4?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=772&q=80',
          alt: 'Emilia Martínez Image',
        },
      },
      {
        testimonial: `Angie tiene una empatía increíble combinada con una estructura clínica muy sólida. Su acompañamiento en la gestión del estrés y el burnout cambió por completo mi forma de liderar a mi equipo y de cuidar mi salud mental.`,
        name: 'Laura Silva',
        job: 'Fundadora de ONG',
        image: {
          src: 'https://images.unsplash.com/photo-1554727242-741c14fa561c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
          alt: 'Laura Silva Image',
        },
      },
      {
        testimonial: `El trabajo con la técnica de Time Line Therapy® fue un antes y un después. Me permitió liberar cargas emocionales profundas del pasado de una manera compasiva, segura y sin resistencias. Siento una ligereza que no experimentaba en años.`,
        name: 'Alejandro Fuentes',
        job: 'Consultor Independiente',
        image: {
          src: 'https://images.unsplash.com/photo-1599566150163-29194dcaad36?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
          alt: 'Alejandro Fuentes Image',
        },
      },
      {
        testimonial: `Lo que más valoro es que el espacio es 100% confidencial, seguro y libre de juicios. Al ser las sesiones virtuales, pude llevar mi proceso con total comodidad desde casa sin perder la calidez ni el impacto del tratamiento.`,
        name: 'Jessica Collado',
        job: 'Diseñadora UX',
        image: {
          src: 'https://images.unsplash.com/photo-1548142813-c348350df52b?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=778&q=80',
          alt: 'Jessica Collado Image',
        },
      },
      {
        testimonial: `Su enfoque integral de mente, cuerpo y emociones realmente funciona. Aprendí a identificar el origen de mi diálogo interno negativo y a reprogramarlo usando los anclajes de PNL. Angie es una profesional extraordinaria.`,
        name: 'Miguel Castro',
        job: 'Coordinador de Operaciones',
        image: {
          src: 'https://images.unsplash.com/photo-1566492031773-4f4e44671857?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
          alt: 'Miguel Castro Image',
        },
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="Comienza tu proceso de cambio hoy"
    subtitle="Las consultas y sesiones se llevan a cabo de manera 100% virtual a través de plataformas seguras, garantizando total confidencialidad y comodidad desde el lugar donde te encuentres."
    actions={[
      {
        variant: 'primary',
        text: 'Solicitar Consulta Gratuita',
        target: '_blank',
        href: 'https://wa.me/51987717886?text=Hola%20Psic.%20Angie%2C%20me%20gustar%C3%ADa%20solicitar%20la%20consulta%20gratuita%20de%2010%20minutos%20para%20conocer%20m%C3%A1s%20sobre%20las%20sesiones.',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    items={[
      {
        title: 'WhatsApp',
        description: '+51 987 717 886',
        icon: 'tabler:headset',
      },
      {
        title: 'Email',
        description: 'angiewong.psicologa@gmail.com',
