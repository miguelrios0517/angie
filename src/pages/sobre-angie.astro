---
import Layout from '~/layouts/PageLayoutAngie.astro';

import Header from '~/components/widgets/Header.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Steps from '~/components/widgets/Steps.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Personal Homepage Demo',
};
---

<Layout metadata={metadata}>
  <Fragment slot="announcement"></Fragment>

  <!-- Hero2 Widget ******************* -->

  <Hero
    id="hero"
    title="Psic. Angie Wong"
    tagline="Sobre Angie"
    actions={[{ variant: 'primary', text: 'Agendar Sesión Virtual', href: getPermalink('/contact#form') }]}
  >
    <Fragment slot="subtitle">
      Psicóloga Clínica, Coach Mental & Master en PNL CPP. 14690. <br /><br /> Mi objetivo es brindar un enfoque integral,
      compasivo e innovador en el cuidado de la salud mental, adaptando cada herramienta a la historia y necesidades únicas
      de mis pacientes.
    </Fragment>
  </Hero>

  <!-- Content Widget **************** -->

  <Content
    id="about"
    columns={3}
    items={[
      {
        icon: 'tabler:brand-dribbble',
        callToAction: {
          target: '_blank',
          text: 'Dribbble',
          href: '#',
        },
      },
      {
        icon: 'tabler:brand-behance',
        callToAction: {
          target: '_blank',
          text: 'Behance',
          href: '#',
        },
      },
      {
        icon: 'tabler:brand-pinterest',
        callToAction: {
          target: '_blank',
          text: 'Pinterest',
          href: '#',
        },
      },
    ]}
    image={{
      src: '~/assets/images/angiewong.jpg',
      alt: 'Colorful Image',
      loading: 'eager',
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Perfil Profesional (Biografía Narrativa)
      </h2>
      <p>
        Soy Licenciada en Psicología con un enfoque apasionado en guiar a las personas a superar desafíos emocionales y
        de salud mental complejos, tales como la ansiedad, la depresión y los trastornos de personalidad.
      </p>
      <br />
      <p>
        Mi práctica se distingue por fusionar la rigurosidad de la Psicología Clínica con el dinamismo estratégico de la
        Programación Neurolingüística (PNL) y el Coaching. Cuento con maestrías en Psicología Clínica y de la Salud y en
        Terapia del Bienestar Emocional (Madrid, España), lo que me permite abordar la salud mental desde una
        perspectiva integral: conectando mente, cuerpo y emociones.
      </p>
      <br />
      <p>
        Además de mi trayectoria en consulta particular, he sido docente universitaria durante más de una década, una
        experiencia clave que alimenta constantemente mi actualización profesional. Sin embargo, mi aprendizaje más
        valioso proviene de la interacción diaria con mis pacientes y del compromiso mutuo hacia su transformación
        duradera.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    id="resume"
    title="Trayectoria Académica"
    items={[
      {
        title: `Máster en Terapia del Bienestar Emocional<br /> <span class="font-normal">CEU Universidad San Pablo (Madrid, España)</span> <br /> <span class="text-sm font-normal">2020 - 2021</span>`,
        icon: 'tabler:school',
      },
      {
        title: `Maestría en Psicología Clínica y de la Salud<br /> <span class="font-normal">Universidad de San Martín de Porres</span> <br /> <span class="text-sm font-normal">2008 - 2010</span>`,
        icon: 'tabler:school',
      },
      {
        title: `Licenciatura en Psicología y Humanidade<br /> <span class="font-normal">Universidad Femenina del Sagrado Corazón (UNIFE)</span> <br /> <span class="text-sm font-normal">2000 - 2006</span>`,
        icon: 'tabler:school',
      },
      {
        title: `Certificación Internacional en Coaching Neurológico<br /> <span class="font-normal">Jamming Consultoría</span> <br /> <span class="text-sm font-normal">2017</span>`,
        icon: 'tabler:school',
      },
      {
        title: `Certificación Internacional en Gestión de la Innovación<br /> <span class="font-normal">Latam Coaching Network</span> <br /> <span class="text-sm font-normal">2018</span>`,
        icon: 'tabler:school',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    id="resume"
    title="Experiencia Clave"
    items={[
      {
        title:
          'Consultorio Particular <br /> <span class="font-normal">Consulto Personal, Lima</span> <br /> <span class="text-sm font-normal">2007 - Actualidad</span>',
        description: `Psicóloga Clínica y Coach orientada a adolescentes y adultos en manejo de estrés, crisis de pareja, ansiedad, depresión y trastornos de la conducta alimentaria (anorexia/bulimia).`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Docencia Universitaria <br /> <span class="font-normal">Universidad Continental y Alas Peruanas, Lima</span> <br /> <span class="text-sm font-normal">2008 - 2021</span>',
        description: `Profesora de pregrado y modalidades virtuales en la Universidad Continental y la Universidad Alas Peruanas, dictando asignaturas como Psicología Clínica, Técnicas Psicoterapéuticas y Psicología de la Motivación.`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Investigación y Desarrollo Social <br /> <span class="font-normal">Miniesterio de Educacion, Lima</span> <br /> <span class="text-sm font-normal">2008 - 2021</span>',
        description: `Evaluadora de proyectos educativos para el Ministerio de Educación y psicóloga de investigación de mercados en 360° Inteligencia de Mercados IBC.`,
        icon: 'tabler:briefcase',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="Certificaciones & Habilidades Clave"
    subtitle="Integración de herramientas clínicas y estratégicas para una transformación profunda."
    columns={3}
    defaultIcon="tabler:point-filled"
    items={[
      {
        title: 'EFT Tapping',
        description: 'Liberación emocional para procesar bloqueos internos y reducir el estrés físico.',
      },
      {
        title: 'Programación Neurolingüística (PNL)',
        description: 'Reestructuración de patrones de pensamiento y optimización de la comunicación interna.',
      },
      {
        title: 'Hipnosis Ericksoniana',
        description: 'Modificación de conductas arraigadas mediante el acceso guiado al inconsciente.',
      },
      {
        title: 'Gestión de la Innovación',
        description: 'Enfoque metodológico moderno y ágil para encontrar soluciones clínicas efectivas.',
      },
      {
        title: 'Coaching Neurológico',
        description: 'Potenciación de habilidades individuales para maximizar el rendimiento personal.',
      },
      {
        title: 'Consultoría en PNL',
        description: 'Diseño de estrategias personalizadas para superar creencias limitantes rápidamente.',
      },
      {
        title: 'Coaching Metódico',
        description: 'Acompañamiento enfocado en superar obstáculos y alcanzar metas individuales reales.',
      },
      {
        title: 'Enfoque Transpersonal',
        description: 'Integración de la sombra junguiana y arquetipos para sanar la identidad profunda.',
      },
      {
        title: 'Time Line Therapy®',
        description: 'Desensibilización de eventos del pasado para liberar cargas emocionales flotantes.',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    id="porfolio"
    title="Mi Metodología: ¿Cómo trabajo con la PNL?"
    subtitle="Un laboratorio de transformación para reprogramar tu software mental. Fusiono precisión clínica y PNL para transformar el análisis del pasado en cambios medibles en tu identidad, hábitos y bienestar."
    isReversed
    image={{
      src: 'https://images.unsplash.com/photo-1658248165252-71e116af1b34?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=928&q=80',
      alt: 'Tech Design Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        El Concepto:<br /><span class="text-2xl">¿Qué es la PNL (Programación Neurolingüística)?</span>
      </h3>
      <p>
        Si nunca has escuchado hablar de la PNL, imagínala como el manual de usuario de tu propio cerebro. Tu mente
        funciona a través de un software que se ha ido programando desde tu infancia con base en tus experiencias,
        miedos y entorno. <br /><br />La PNL es un conjunto de herramientas prácticas que nos permite auditar ese
        "software mental", identificar qué pensamientos te están limitando y reprogramar tu cerebro para que reaccione
        con calma, seguridad y claridad, en lugar de activar el estrés de manera automática.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent={true}
    items={[
      {
        title: 'Programación',
        description:
          'Identificamos tus hábitos y automatismos mentales. Sustituimos los patrones de ansiedad y autosabotaje por programas que impulsen tu bienestar.',
      },
      {
        title: 'Neuro',
        description: `Optimizamos tu sistema nervioso. Es la forma en que tu cerebro procesa y almacena la realidad a través de imágenes, sonidos y sensaciones físicas.`,
      },
      {
        title: 'Lingüística',
        description: `Ajustamos tu lenguaje. Tanto tus palabras como tu diálogo interno programan directamente tus emociones y tu capacidad de reacción ante el mundo.`,
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1619983081563-430f63602796?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
      alt: 'Art and Music Poster Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Los Componentes:<br /><span class="text-2xl">Los Pilares del Cambio</span>
      </h3>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent={true}
    items={[
      {
        title: 'Descodificación de Creencias',
        description: `Auditamos tu discurso para detectar bloqueos. Usamos Hipnosis Ericksoniana Ligera (trance conversacional) para conectar con el origen de tus patrones inconscientes sin activar resistencias.`,
      },
      {
        title: 'Edición Mental y Liberación Somática',
        description: `Alteramos la estructura de los recuerdos dolorosos para neutralizar su carga. Combinamos PNL con EFT Tapping Clínico (estímulo de puntos meridianos) para reducir el cortisol y liberar el estrés de tu biología.`,
      },
      {
        title: 'Anclajes de Alto Rendimiento',
        description: `Creamos disparadores en tu cuerpo para acceder a estados de calma y enfoque. Mediante Hipnosis Profunda, sembramos estas herramientas en tu inconsciente para que las actives a voluntad ante cualquier desafío.`,
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1664455340023-214c33a9d0bd?ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=870&q=80',
      alt: 'Fashion e-commerce Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        La Aplicación: <br /><span class="text-2xl">Tres Ejes de Acción en Sesión</span>
      </h3>
      <p>Aplicamos la PNL mediante procesos lógicos diseñados para transformar tu realidad interna:</p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Testimonials Widget *********** -->

  <Testimonials
    title="Lo Que Dicen Mis Clientes"
    subtitle="Testimonios e historias reales de superación y crecimiento personal."
    testimonials={[
      {
        testimonial: `She took our vague concept and turned it into a visual masterpiece that perfectly aligned with our goals. Her attention to detail and ability to translate ideas into compelling visuals exceeded our expectations.`,
        name: 'Mark Thompson',
        job: 'Creative director',
        image: {
          src: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
          alt: 'Mark Thompson Image',
        },
      },
      {
        testimonial: `She transformed our brand identity with her creative finesse, capturing our essence in every element. Her dedication and talent truly shine through her work.`,
        name: 'Emily Martinez',
        job: 'CEO',
        image: {
          src: 'https://images.unsplash.com/photo-1554151228-14d9def656e4?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=772&q=80',
          alt: 'Emily Martinez Image',
        },
      },
      {
        testimonial: `She has an uncanny ability to communicate emotions and stories. She crafted a logo for our NGO that not only represents our cause but also evokes empathy. Her professionalism and commitment make her a designer of exceptional caliber.`,
        name: 'Laura Simmons',
        job: 'Founder of an NGO',
        image: {
          src: 'https://images.unsplash.com/photo-1554727242-741c14fa561c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
          alt: 'Laura Simmons Image',
        },
      },
      {
        testimonial: `We entrusted Sarah with revamping our website's user interface, and the results were astounding. Her intuitive design sense enhanced user experience, leading to a significant increase in engagement. She's a designer who truly understands the synergy of aesthetics and functionality.`,
        name: 'Alex Foster',
        job: 'Director of web services',
        image: {
          src: 'https://images.unsplash.com/photo-1599566150163-29194dcaad36?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
          alt: 'Alex Foster Image',
        },
      },
      {
        testimonial: `She took our vision and elevated it beyond imagination. Her ability to capture brand essence and translate it into design is nothing short of remarkable. Working with her has been an inspiring journey.`,
        name: 'Jessica Collins',
        job: 'Product Manager',
        image: {
          src: 'https://images.unsplash.com/photo-1548142813-c348350df52b?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=778&q=80',
          alt: 'Jessica Collins Image',
        },
      },
      {
        testimonial: `Her ability to transform concepts into captivating visuals is nothing short of extraordinary. She took our event poster idea and turned it into a visual masterpiece that perfectly captured the essence of our festival. Sarah's dedication, creativity, and knack for delivering beyond expectations make her an invaluable asset to any project.`,
        name: 'Michael Carter',
        job: 'Event Coordinator',
        image: {
          src: 'https://images.unsplash.com/photo-1566492031773-4f4e44671857?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
          alt: 'Michael Carter Image',
        },
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="Comienza tu proceso de cambio hoy"
    subtitle="Las consultas y sesiones se llevan a cabo de manera 100% virtual a través de plataformas seguras, garantizando total confidencialidad y comodidad desde el lugar donde te encuentres."
    actions={[
      {
        variant: 'primary',
        text: 'Solicitar Consulta Gratuita',
        href: '/',
      },
    ]}
  />

  <!-- BlogLatestPost Widget **************** -->

  <BlogLatestPosts
    id="blog"
    title="Explore my insightful articles on my blog"
    information={`Dive into a realm of design wisdom and creative inspiration, where you'll find invaluable insights, practical tips, and captivating narratives that elevate and enrich your creative journey.`}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </BlogLatestPosts>
</Layout>
